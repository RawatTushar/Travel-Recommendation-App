PORT=4000
MONGODB_URI=
JWT_SECRET=

# Base URL of this API as opened from the user's device (for email links).
# Dev on same machine: http://localhost:4000
# Physical phone opening the email: http://YOUR_PC_LAN_IP:4000 or https://your-ngrok-url
PUBLIC_API_BASE_URL=http://1192.168.1.2:4000

# Optional: real email (Gmail app password, SendGrid SMTP, etc.). If omitted, the server logs the link to the console.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=Wander <noreply@yourdomain.com>

VERIFICATION_EXPIRE_HOURS=48
